# ============================================================================
# Staging Environment Configuration — Lorenco Ecosystem
# ============================================================================
# Copy this file to .env when setting up the staging Zeabur service.
# NEVER commit a real .env file. These are example values only.
#
# STAGING must point to a SEPARATE Supabase project from production.
# This is the only way to guarantee staging cannot damage live client data.
#
# Setup: Create a second Supabase project named "lorenco-staging" and
# use those credentials here. See docs/paytime-release-process.md for
# the full setup walkthrough.
# ============================================================================

NODE_ENV=staging

# ── Supabase (STAGING project — separate from production) ──────────────────
SUPABASE_URL=https://YOUR-STAGING-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.STAGING_SERVICE_KEY
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.STAGING_ANON_KEY

# ── Direct PostgreSQL connection (staging) ─────────────────────────────────
# Required for pg Pool routes: accounting, journals, bank, suppliers, reports
DATABASE_URL=postgresql://postgres:STAGING-PASSWORD@db.YOUR-STAGING-PROJECT.supabase.co:5432/postgres
ACCOUNTING_DATABASE_URL=postgresql://postgres:STAGING-PASSWORD@db.YOUR-STAGING-PROJECT.supabase.co:5432/postgres

# ── JWT ────────────────────────────────────────────────────────────────────
# Use a DIFFERENT secret from production — prevents staging tokens from
# being used in production and vice versa.
JWT_SECRET=staging-jwt-secret-change-this-to-something-strong-and-unique

# ── Module Flags ───────────────────────────────────────────────────────────
MODULE_POS_ENABLED=true
MODULE_PAYROLL_ENABLED=true
MODULE_ACCOUNTING_ENABLED=true
MODULE_SEAN_ENABLED=true

# ── App URL (your staging Zeabur domain) ──────────────────────────────────
APP_URL=https://lorenco-staging.zeabur.app

# ── Build version ─────────────────────────────────────────────────────────
# Zeabur injects BUILD_VERSION automatically. Leave blank here.
# BUILD_VERSION=

# ── SEAN / AI ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR-STAGING-OR-DEV-API-KEY

# ── Environment label (shown in server startup and health endpoint) ────────
ENVIRONMENT_LABEL=staging
