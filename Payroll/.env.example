# =============================================================================
# Lorenco Paytime — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your Supabase values.
#
# ZEABUR DEPLOYMENT:
#   Set these as Environment Variables in the Zeabur dashboard.
#   Do NOT commit a .env file with real credentials to Git.
# =============================================================================

# Supabase Connection (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Server Port (Zeabur sets PORT automatically)
PORT=3131
