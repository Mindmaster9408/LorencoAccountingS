# Supabase PostgreSQL Connection (recommended — single URL)
DATABASE_URL=postgresql://postgres.glkndlzjkhwfsolueyhk:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Or use individual variables:
# DB_HOST=aws-0-eu-west-1.pooler.supabase.com
# DB_PORT=6543
# DB_NAME=postgres
# DB_USER=postgres.glkndlzjkhwfsolueyhk
# DB_PASSWORD=your-supabase-db-password

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Secret (generate a random string for production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# AI API Keys
ANTHROPIC_API_KEY=your_claude_api_key_here
GROK_API_KEY=your_grok_api_key_here

# AI Configuration
PRIMARY_AI_PROVIDER=claude
FALLBACK_AI_PROVIDER=grok

# CORS Origins (comma separated)
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
